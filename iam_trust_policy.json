{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "SSMAutomationTrust",
      "Effect": "Allow",
      "Principal": {
        "Service": "ssm.amazonaws.com"
      },
      "Action": "sts:AssumeRole",
      "Condition": {
        "StringEquals": {
          "aws:SourceAccount": "<CENTRAL_ACCOUNT_ID>"
        }
      }
    }
  ]
}
